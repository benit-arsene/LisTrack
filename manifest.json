{
  "manifest_version": 3,
  "name": "LisTrack - Personal Screen Time Tracker",
  "version": "1.0.0",
  "description": "Automatically track active screen-time on websites you visit and send it to your remote dashboard.",
  "permissions": [
    "notifications",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://listrack.onrender.com/*",
    "https://listrack-2.onrender.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "LisTrack - Open Dashboard",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["tracker.js"],
      "run_at": "document_end"
    }
  ]
}
